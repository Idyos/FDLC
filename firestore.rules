rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function hasPerm(list, perm) {
      return list != null && ('*' in list || perm in list);
    }

    function authed() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/Users/$(request.auth.uid);
    }

    function userExists() {
      return authed() && exists(userPath());
    }

    function canProves(perm) {
      return userExists() && hasPerm(get(userPath()).data.permissions.proves, perm);
    }

    function canPenyes(perm) {
      return userExists() && hasPerm(get(userPath()).data.permissions.penyes, perm);
    }

    function canUsers(perm) {
      return userExists() && hasPerm(get(userPath()).data.permissions.users, perm);
    }

    function canEditResults(provaId) {
      return userExists()
        && hasPerm(get(userPath()).data.permissions.proves, 'editResults')
        && (
          !('specificProvaId' in get(userPath()).data.permissions)
          || get(userPath()).data.permissions.specificProvaId == provaId
        );
    }

    match /Users/{userId} {
      allow get, list: if true;
      allow create, delete: if authed();
      allow update: if authed() && (
        request.auth.uid == userId || canUsers('edit')
      );
    }

    match /Circuit/{year} {
      allow get, list: if true;

      match /Proves/{provaId} {
        allow get, list: if true;
        allow create: if canProves('create');
        allow update: if canProves('editInfo');
        allow delete: if canProves('delete');

        match /Participants/{participantId} {
          allow get, list: if true;
          allow create, update, delete: if canEditResults(provaId);
        }

        match /Bracket/{bracketId} {
          allow get, list: if true;
          allow create, update, delete: if canEditResults(provaId);
        }

        match /SubProves/{subProvaId} {
          allow get, list: if true;
          allow create, update, delete: if canProves('editInfo') || canEditResults(provaId);

          match /Participants/{participantId} {
            allow get, list: if true;
            allow create, update, delete: if canEditResults(provaId);
          }

          match /Bracket/{bracketId} {
            allow get, list: if true;
            allow create, update, delete: if canEditResults(provaId);
          }
        }
      }

      match /Penyes/{penyaId} {
        allow get, list: if true;
        allow create: if canPenyes('create');
        allow update: if canPenyes('edit');
        allow delete: if canPenyes('delete');
      }

      match /Results/{resultId} {
        allow get, list: if true;
        allow create, update, delete: if canProves('editResults');
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
