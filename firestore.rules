rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function userDocExists() {
      return isAuth() && exists(/databases/$(database)/documents/Users/$(request.auth.uid));
    }

    function userPerms() {
      return get(/databases/$(database)/documents/Users/$(request.auth.uid)).data.permissions;
    }

    function hasPerm(permList, perm) {
      return '*' in permList || perm in permList;
    }

    function canDo(section, perm) {
      return hasPerm(userPerms()[section], perm);
    }

    function canEditResults(provaId) {
      return hasPerm(userPerms().proves, 'editResults') && (
        !('specificProvaId' in userPerms()) ||
        userPerms().specificProvaId == provaId
      );
    }

    match /Users/{userId} {
      allow get, list: if true;
      allow create, delete: if isAuth();
      allow update: if isAuth() && (
        request.auth.uid == userId ||
        (userDocExists() && canDo('users', 'edit'))
      );
    }

    match /Circuit/{year} {
      allow get, list: if true;

      match /Proves/{provaId} {
        allow get, list: if true;
        allow create: if userDocExists() && canDo('proves', 'create');
        allow update: if userDocExists() && canDo('proves', 'editInfo');
        allow delete: if userDocExists() && canDo('proves', 'delete');

        match /Participants/{participantId} {
          allow get, list: if true;
          allow create, update, delete: if userDocExists() && canEditResults(provaId);
        }

        match /Bracket/{bracketId} {
          allow get, list: if true;
          allow create, update, delete: if userDocExists() && canEditResults(provaId);
        }

        match /SubProves/{subProvaId} {
          allow get, list: if true;
          allow create, update, delete: if userDocExists() && (
            canDo('proves', 'editInfo') || canEditResults(provaId)
          );

          match /Participants/{participantId} {
            allow get, list: if true;
            allow create, update, delete: if userDocExists() && canEditResults(provaId);
          }

          match /Bracket/{bracketId} {
            allow get, list: if true;
            allow create, update, delete: if userDocExists() && canEditResults(provaId);
          }
        }
      }

      match /Penyes/{penyaId} {
        allow get, list: if true;
        allow create: if userDocExists() && canDo('penyes', 'create');
        allow update: if userDocExists() && canDo('penyes', 'edit');
        allow delete: if userDocExists() && canDo('penyes', 'delete');
      }

      match /Results/{resultId} {
        allow get, list: if true;
        allow create, update, delete: if userDocExists() && canDo('proves', 'editResults');
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
